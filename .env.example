NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Herramienta de redacción con IA (/redactar) ---

# API key gratuita de Google AI Studio (https://aistudio.google.com/apikey)
# Se usa para estructurar el texto del call center con Gemini.
GOOGLE_GENERATIVE_AI_API_KEY=

# Token de GitHub (fine-grained) con permiso "Contents: Read and write"
# sobre el repositorio del FAQ. Permite publicar (commit) los artículos nuevos.
GITHUB_TOKEN=

# Repositorio destino (por defecto: Juancalidoso01/FAQ, rama main)
GITHUB_OWNER=Juancalidoso01
GITHUB_REPO=FAQ
GITHUB_BRANCH=main

# Opcional: si defines una clave, /redactar pedirá contraseña para usarse.
# Si la dejas vacía, la herramienta queda abierta.
REDACTAR_PASSWORD=
