{
  "name": "faq-punto-pago",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scrape": "python3 scripts/scrape-intercom.py && python3 scripts/scrape-gitbook.py && python3 scripts/scrape-gitbook-guia.py",
    "scrape:intercom": "python3 scripts/scrape-intercom.py",
    "scrape:gitbook": "python3 scripts/scrape-gitbook.py && python3 scripts/scrape-gitbook-guia.py",
    "scrape:gitbook-guia": "python3 scripts/scrape-gitbook-guia.py",
    "deploy:prod": "npx --yes vercel@latest deploy --prod --yes",
    "vercel:whoami": "npx --yes vercel@latest whoami",
    "vercel:env": "npx --yes vercel@latest env ls"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
